[Application]
name=io.kitotsu.KitoWall
runtime=org.gnome.Platform/x86_64/48
sdk=org.gnome.Sdk/x86_64/48
command=kitowall-ui

[Context]
shared=network;
sockets=wayland;
devices=dri;
filesystems=home;xdg-pictures;

[Session Bus Policy]
org.freedesktop.Flatpak=talk

[Environment]
WEBKIT_DISABLE_DMABUF_RENDERER=1

[Extension io.kitotsu.KitoWall.Debug]
directory=lib/debug
autodelete=true
no-autodownload=true

[Build]
built-extensions=io.kitotsu.KitoWall.Debug;